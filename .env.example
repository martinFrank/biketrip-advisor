# Ollama Server URL
# Lokal (ohne Docker): http://localhost:11434
# In Docker (Windows/Mac): http://host.docker.internal:11434
BIKETRIP_OLLAMA_BASE_URL=http://host.docker.internal:11434

# LLM-Modelle pro Agent-Rolle
# Verfügbare Modelle anzeigen: ollama list
BIKETRIP_OLLAMA_CHAT_MODEL=mistral
BIKETRIP_OLLAMA_REASONING_MODEL=deepseek-r1:8b
BIKETRIP_OLLAMA_PLANNING_MODEL=qwen2.5:7b
BIKETRIP_OLLAMA_LANGUAGE_MODEL=llama3.1:8b
